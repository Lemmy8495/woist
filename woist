        f"VPN={geo.get('vpn_proxy_verdacht', {}).get('verdacht', '-')}"
    )


def print_cache_info() -> None:
    stats = cache_stats()
    print(f"Cache-Datei:      {stats['datei']}")
    print(f"Eintraege:        {stats['eintraege']}")
    print(f"Aelteste UNIX:    {stats['aelteste_unix']}")
    print(f"Neueste UNIX:     {stats['neuste_unix']}")


HELP_TEXT = f"""woist {APP_VERSION}

Kurzbeschreibung:
  CLI-Tool zur Analyse von IPs, Domains und URLs.
  Es kombiniert DNS, GeoIP, ASN/Netzbereich, Whois, Ping, Traceroute, Portcheck, TLS und HTTP/CDN-Analyse.

Aufruf:
  woist [OPTIONEN] ziel
  woist [OPTIONEN] ziel1 ziel2 ziel3
  woist [OPTIONEN] --file datei.txt

Wichtige Befehle / Optionen:
  -h, --help, -help     Zeigt diesen Hilfebereich mit allen Befehlen an
  --json                Gibt die Ausgabe als JSON aus
  --compact             Kompakte Ein-Zeilen-Ausgabe
  --table               Tabellarische Kurz-Ausgabe
  --raw                 Ausgabe ohne Styling / ohne Farben
  --no-color            Deaktiviert Farbausgabe

Ziele:
  ziel                  IP-Adresse, Domain oder URL
  --file DATEI          Liest mehrere Ziele aus einer Datei

DNS:
  --dns IP              Nutzt einen bestimmten DNS-Server für Abfragen
  --ip                  Zeigt die bevorzugte aufgelöste IP an
  --all                 Zeigt alle gefundenen DNS-Daten an

GeoIP / ASN / Cache:
  --asn                 Hebt ASN-, CIDR-, RIR- und Owner-Bereich hervor
  --cache-info          Zeigt Infos zum lokalen Cache
  --clear-cache         Löscht den lokalen Cache

Netzwerk:
  --whois               Zeigt kompakte Whois-Daten
  --ping                Führt einen kurzen Ping aus
  --trace               Führt ein kurzes Traceroute aus
  --ports LISTE         Prüft TCP-Ports, z. B. 80,443,22
  --tls                 Führt TLS-/HTTPS-Zertifikatsanalyse aus
  --http                Führt HTTP-/Server-/CDN-/Security-Header-Analyse aus

Export:
  --out DATEI           Exportiert Ergebnis nach .json, .csv oder .md

Beispiele:
  woist github.com
  woist --all github.com
  woist --asn github.com
  woist --dns 8.8.8.8 github.com
  woist --whois --ping github.com
  woist --trace --ports 80,443 github.com
  woist --tls github.com
  woist --http github.com
  woist --file targets.txt --compact
  woist --out report.json github.com
  woist --out report.csv github.com
  woist --out report.md github.com
"""


def main() -> int:
    if any(arg in ("-h", "--help", "-help") for arg in sys.argv[1:]):
        print(HELP_TEXT)
        return 0

    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("ziele", nargs="*", help="IP-Adresse, URL oder Hostname")
    parser.add_argument("--file", help="liest zusätzliche Ziele aus einer Datei")
    parser.add_argument("--dns", dest="dns_server", help="nutzt diesen DNS-Server für Abfragen")
    parser.add_argument("--json", action="store_true", dest="json_output", help="gibt die Ausgabe als JSON aus")
    parser.add_argument("--ip", action="store_true", help="zeigt die bevorzugte aufgelöste IP an")
    parser.add_argument("--all", action="store_true", help="zeigt alle gefundenen DNS-Daten an")
    parser.add_argument("--asn", action="store_true", help="zeigt ASN-, Netzbereich- und RIR-Infos deutlich an")
    parser.add_argument("--whois", action="store_true", help="zeigt eine kompakte whois-Auswertung an")
    parser.add_argument("--ping", action="store_true", help="führt einen kurzen Ping auf die bevorzugte IP aus")
    parser.add_argument("--trace", action="store_true", help="führt ein kurzes traceroute aus")
    parser.add_argument("--ports", help="prüft TCP-Ports, z. B. 80,443,22")
    parser.add_argument("--tls", action="store_true", help="führt TLS-/HTTPS-Zertifikatsanalyse aus")
    parser.add_argument("--http", action="store_true", help="führt HTTP-/Server-/CDN-/Security-Header-Analyse aus")
    parser.add_argument("--compact", action="store_true", help="kompakte Ein-Zeilen-Ausgabe")
    parser.add_argument("--table", action="store_true", help="tabellarische Kurz-Ausgabe")
    parser.add_argument("--raw", action="store_true", help="zeigt Rohdaten ohne Styling")
    parser.add_argument("--no-color", action="store_true", help="deaktiviert Farbausgabe")
    parser.add_argument("--out", help="exportiert Ergebnis nach .json, .csv oder .md")
    parser.add_argument("--cache-info", action="store_true", help="zeigt Infos zum lokalen Cache")
    parser.add_argument("--clear-cache", action="store_true", help="löscht den lokalen Cache")
    args = parser.parse_args()

    try:
        if args.clear_cache:
            removed = clear_cache()
            print("Cache gelöscht." if removed else "Kein Cache vorhanden.")
            return 0

        if args.cache_info:
            print_cache_info()
            return 0

        if args.dns_server:
            ipaddress.ip_address(args.dns_server)

        ports = parse_ports(args.ports)
        targets = read_targets(args.ziele, args.file)

        results = []
        for target in targets:
            results.append(
                analyze_target(
                    target=target,
                    nameserver=args.dns_server,
                    with_whois=args.whois,
                    with_ping=args.ping,
                    with_trace=args.trace,
                    with_tls=args.tls,
                    with_http=args.http,
                    ports=ports,
                )
            )

        if args.out:
            export_results(args.out, results)

        if args.json_output:
            print(json.dumps(results if len(results) > 1 else results[0], ensure_ascii=False, indent=2))
            return 0

        use_color = not args.no_color and not args.raw

        for index, result in enumerate(results, start=1):
            if len(results) > 1:
                header = f"[{index}/{len(results)}] {result['eingabe']}"
                print(style(header, BOLD + CYAN, use_color))

            if args.compact:
                print_compact_block(result)
            elif args.table:
                print_table_block(result)
                if args.asn:
                    print()
                    print_asn_block(result["asn"], use_color=False)
                if args.http:
                    print()
                    print_http_block(result["http"], use_color=False)
                if args.whois:
                    print()
                    print_whois_block(result["whois"], use_color=False)
                if args.ping:
                    print()
                    print_ping_block(result["ping"], use_color=False)
                if args.trace:
                    print()
                    print_trace_block(result["trace"], use_color=False)
                if ports:
                    print()
                    print_ports_block(result["ports"], use_color=False)
                if args.tls:
                    print()
                    print_tls_block(result["tls"], use_color=False)
            else:
                print_dns_block(result, show_preferred_ip=args.ip, show_all=args.all, use_color=use_color)
                print()
                print_geo_block(result, use_color=use_color)
                print()
                print_asn_block(result["asn"], use_color=use_color)

                if args.http:
                    print()
                    print_http_block(result["http"], use_color=use_color)

                if args.tls:
                    print()
                    print_tls_block(result["tls"], use_color=use_color)

                if args.whois:
                    print()
                    print_whois_block(result["whois"], use_color=use_color)

                if args.ping:
                    print()
                    print_ping_block(result["ping"], use_color=use_color)

                if args.trace:
                    print()
                    print_trace_block(result["trace"], use_color=use_color)

                if ports:
                    print()
                    print_ports_block(result["ports"], use_color=use_color)

            if len(results) > 1 and index < len(results):
                print()

        return 0

    except KeyboardInterrupt:
        print("Fehler: Abbruch durch Benutzer.", file=sys.stderr)
        return 130
    except ValueError as exc:
        print(f"Fehler: {exc}", file=sys.stderr)
        return 1
    except RuntimeError as exc:
        print(f"Fehler: {exc}", file=sys.stderr)
        return 1
    except Exception as exc:
        print(f"Unerwarteter Fehler: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())