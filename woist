def style(text: str, color: str, use_color: bool) -> str:
    return f"{color}{text}{RESET}" if use_color else text


def uniq(values: list[str]) -> list[str]:
    out = []
    for value in values:
        if value not in out:
            out.append(value)
    return out


def normalize_target(value: str) -> str:
    cleaned = value.strip()
    if not cleaned:
        raise ValueError("Kein Ziel übergeben.")

    for prefix in ("http://", "https://"):
        if cleaned.startswith(prefix):
            cleaned = cleaned[len(prefix):]

    if "/" in cleaned:
        cleaned = cleaned.split("/", 1)[0]

    if cleaned.startswith("[") and "]" in cleaned:
        cleaned = cleaned[1:].split("]", 1)[0]
    elif cleaned.count(":") == 1 and not cleaned.replace(":", "").isdigit():
        cleaned = cleaned.rsplit(":", 1)[0]

    return cleaned.strip().rstrip(".")


def is_ip(value: str) -> bool:
    try:
        ipaddress.ip_address(value)
        return True
    except ValueError:
        return False


def read_targets(single_targets: list[str], file_path: str | None) -> list[str]:
    targets = []
    targets.extend(single_targets)

    if file_path:
        path = Path(file_path)
        if not path.exists():
            raise ValueError(f"Datei nicht gefunden: {file_path}")

        for line in path.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if line and not line.startswith("#"):
                targets.append(line)

    targets = uniq(targets)

    if not targets:
        raise ValueError("Keine Ziele angegeben.")

    return targets


def load_cache() -> dict:
    try:
        if CACHE_FILE.exists():
            return json.loads(CACHE_FILE.read_text(encoding="utf-8"))
    except Exception:
        pass
    return {}


def save_cache(cache: dict) -> None:
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    CACHE_FILE.write_text(json.dumps(cache, ensure_ascii=False, indent=2), encoding="utf-8")


def cache_get(ip: str) -> dict | None:
    cache = load_cache()
    entry = cache.get(ip)

    if not entry:
        return None

    if time.time() - entry.get("timestamp", 0) > CACHE_TTL:
        return None

    return entry.get("data")


def cache_set(ip: str, data: dict) -> None:
    cache = load_cache()
    cache[ip] = {"timestamp": time.time(), "data": data}
    save_cache(cache)


def clear_cache() -> bool:
    if CACHE_FILE.exists():
        CACHE_FILE.unlink()
        return True
    return False


def cache_stats() -> dict:
    cache = load_cache()
    entries = len(cache)
    newest = 0.0
    oldest = None

    for item in cache.values():
        ts = item.get("timestamp", 0)
        if ts > newest:
            newest = ts
        if oldest is None or ts < oldest:
            oldest = ts

    return {
        "datei": str(CACHE_FILE),
        "eintraege": entries,
        "neuste_unix": newest if newest else None,
        "aelteste_unix": oldest,
    }


def resolver_instance(nameserver: str | None) -> dns.resolver.Resolver:
    res = dns.resolver.Resolver()
    if nameserver:
        res.nameservers = [nameserver]
    return res


def query_dns(name: str, record_type: str, nameserver: str | None) -> tuple[list[str], int | None]:
    res = resolver_instance(nameserver)
    try:
        answer = res.resolve(name, record_type)
        values = []
        for item in answer:
            text = item.to_text().strip()
            if text.endswith("."):
                text = text[:-1]
            values.append(text)
        ttl = getattr(answer.rrset, "ttl", None)
        return uniq(values), ttl
    except (dns.resolver.NoAnswer, dns.resolver.NXDOMAIN):
        return [], None
    except dns.exception.DNSException:
        return [], None


def reverse_dns_lookup(ip: str, nameserver: str | None) -> str:
    try:
        rev_name = dns.reversename.from_address(ip)
        answer = resolver_instance(nameserver).resolve(rev_name, "PTR")
        ptr = answer[0].to_text().strip()
        return ptr[:-1] if ptr.endswith(".") else ptr
    except Exception:
        return "-"


def resolve_target(value: str, nameserver: str | None) -> dict:
    cleaned = normalize_target(value)

    if is_ip(cleaned):
        version = ipaddress.ip_address(cleaned).version
        return {
            "eingabe": cleaned,
            "typ": "ip",
            "hostname": None,
            "cname": [],
            "mx": [],
            "ns": [],
            "txt": [],
            "a": [cleaned] if version == 4 else [],
            "aaaa": [cleaned] if version == 6 else [],
            "ttl": {},
            "bevorzugte_ip": cleaned,
            "reverse_dns": reverse_dns_lookup(cleaned, nameserver),
        }

    cname, cname_ttl = query_dns(cleaned, "CNAME", nameserver)
    a_records, a_ttl = query_dns(cleaned, "A", nameserver)
    aaaa_records, aaaa_ttl = query_dns(cleaned, "AAAA", nameserver)
    mx_records, mx_ttl = query_dns(cleaned, "MX", nameserver)
    ns_records, ns_ttl = query_dns(cleaned, "NS", nameserver)
    txt_records, txt_ttl = query_dns(cleaned, "TXT", nameserver)

    if not a_records and not aaaa_records and cname:
        for alias in cname:
            if not a_records:
                a_records, a_ttl = query_dns(alias, "A", nameserver)
            if not aaaa_records:
                aaaa_records, aaaa_ttl = query_dns(alias, "AAAA", nameserver)

    if not a_records and not aaaa_records:
        raise RuntimeError(f"Keine A- oder AAAA-Records für {cleaned} gefunden.")

    preferred = a_records[0] if a_records else aaaa_records[0]

    return {
        "eingabe": cleaned,
        "typ": "hostname",
        "hostname": cleaned,
        "cname": cname,
        "mx": mx_records,
        "ns": ns_records,
        "txt": txt_records,
        "a": a_records,
        "aaaa": aaaa_records,
        "ttl": {
            "CNAME": cname_ttl,
            "A": a_ttl,
            "AAAA": aaaa_ttl,
            "MX": mx_ttl,
            "NS": ns_ttl,
            "TXT": txt_ttl,
        },
        "bevorzugte_ip": preferred,
        "reverse_dns": reverse_dns_lookup(preferred, nameserver),
    }


def http_json(url: str, user_agent: str) -> dict:
    req = urllib.request.Request(url, headers={"User-Agent": user_agent})
    try:
        with urllib.request.urlopen(req, timeout=10) as response:
            return json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as exc:
        raise RuntimeError(f"HTTP-Fehler bei API-Abfrage: {exc.code}") from exc
    except urllib.error.URLError as exc:
        raise RuntimeError(f"Netzwerkfehler bei API-Abfrage: {exc.reason}") from exc
    except json.JSONDecodeError as exc:
        raise RuntimeError("Ungültige JSON-Antwort erhalten.") from exc


def lookup_ip_api(target: str) -> dict:
    data = http_json(IP_API_URL.format(target=urllib.parse.quote(target, safe="")), f"woist/{APP_VERSION}")
    if data.get("status") != "success":
        raise RuntimeError(data.get("message", "ip-api Fehler"))

    return {
        "quelle": "ip-api",
        "ziel_ip": data.get("query", target),
        "land": data.get("country", "-"),
        "region": data.get("regionName", "-"),
        "stadt": data.get("city", "-"),
        "plz": data.get("zip", "-"),
        "breitengrad": data.get("lat", "-"),
        "laengengrad": data.get("lon", "-"),
        "zeitzone": data.get("timezone", "-"),
        "isp": data.get("isp", "-"),
        "organisation": data.get("org", "-"),
        "as": data.get("as", "-"),
        "reverse_dns_api": data.get("reverse", "-"),
        "hosting": bool(data.get("hosting")),
        "proxy": bool(data.get("proxy")),
        "mobile": bool(data.get("mobile")),
    }


def lookup_ipwhois(target: str) -> dict:
    data = http_json(IPWHO_URL.format(target=urllib.parse.quote(target, safe="")), f"woist/{APP_VERSION}")
    if not data.get("success", False):
        raise RuntimeError(data.get("message", "ipwho.is Fehler"))

    connection = data.get("connection", {}) or {}
    return {
        "quelle": "ipwho.is",
        "ziel_ip": data.get("ip", target),
        "land": data.get("country", "-"),
        "region": data.get("region", "-"),
        "stadt": data.get("city", "-"),
        "plz": data.get("postal", "-"),
        "breitengrad": data.get("latitude", "-"),
        "laengengrad": data.get("longitude", "-"),
        "zeitzone": (data.get("timezone", {}) or {}).get("id", "-"),
        "isp": connection.get("isp", "-"),
        "organisation": connection.get("org", "-"),
        "as": connection.get("asn", "-"),
        "network": {
            "cidr": connection.get("cidr", "-"),
            "route": connection.get("route", "-"),
        },
        "reverse_dns_api": "-",
        "hosting": False,
        "proxy": False,
        "mobile": False,
    }


def run_whois(target: str) -> str:
    whois_path = shutil.which("whois")
    if not whois_path:
        return "whois ist auf diesem System nicht verfügbar."

    try:
        result = subprocess.run(
            [whois_path, target],
            capture_output=True,
            text=True,
            timeout=15,
            check=False,
        )
    except subprocess.TimeoutExpired:
        return "whois Timeout."
    except Exception as exc:
        return f"whois Fehler: {exc}"

    output = (result.stdout or "").strip()
    if not output:
        return "Keine whois Ausgabe erhalten."

    return output


def extract_whois_network_info(whois_text: str) -> dict:
    info = {
        "cidr": "-",
        "route": "-",
        "inetnum": "-",
        "inet6num": "-",
        "netname": "-",
        "owner": "-",
        "org": "-",
        "country": "-",
        "origin": "-",
        "rir": "-",
    }

    if not whois_text:
        return info

    lines = whois_text.splitlines()
    for raw in lines:
        line = raw.strip()
        low = line.lower()

        if low.startswith("cidr:") and info["cidr"] == "-":
            info["cidr"] = line.split(":", 1)[1].strip()
        elif low.startswith("route:") and info["route"] == "-":
            info["route"] = line.split(":", 1)[1].strip()
        elif low.startswith("inetnum:") and info["inetnum"] == "-":
            info["inetnum"] = line.split(":", 1)[1].strip()
        elif low.startswith("inet6num:") and info["inet6num"] == "-":
            info["inet6num"] = line.split(":", 1)[1].strip()
        elif low.startswith("netname:") and info["netname"] == "-":
            info["netname"] = line.split(":", 1)[1].strip()
        elif low.startswith("orgname:") and info["owner"] == "-":
            info["owner"] = line.split(":", 1)[1].strip()
        elif low.startswith("organization:") and info["owner"] == "-":
            info["owner"] = line.split(":", 1)[1].strip()
        elif low.startswith("owner:") and info["owner"] == "-":
            info["owner"] = line.split(":", 1)[1].strip()
        elif low.startswith("org:") and info["org"] == "-":
            info["org"] = line.split(":", 1)[1].strip()
        elif low.startswith("country:") and info["country"] == "-":
            info["country"] = line.split(":", 1)[1].strip()
        elif low.startswith("origin:") and info["origin"] == "-":
            info["origin"] = line.split(":", 1)[1].strip()

    text = whois_text.lower()
    if "arin" in text:
        info["rir"] = "ARIN"
    elif "ripe" in text:
        info["rir"] = "RIPE NCC"
    elif "apnic" in text:
        info["rir"] = "APNIC"
    elif "lacnic" in text:
        info["rir"] = "LACNIC"
    elif "afrinic" in text:
        info["rir"] = "AFRINIC"

    return info


def lookup_geo_with_cache(target: str) -> tuple[dict, dict, bool]:
    cached = cache_get(target)
    if cached:
        return cached["primary"], cached["secondary"], True

    primary = lookup_ip_api(target)
    secondary = lookup_ipwhois(target)
    cache_set(target, {"primary": primary, "secondary": secondary})

    return primary, secondary, False


def compare_geo_sources(primary: dict, secondary: dict) -> dict:
    fields = ["land", "region", "stadt", "isp", "organisation", "as"]
    matches = {}

    for field in fields:
        matches[field] = str(primary.get(field, "-")).strip().lower() == str(secondary.get(field, "-")).strip().lower()

    score = sum(1 for value in matches.values() if value)
    if score >= 5:
        confidence = "hoch"
    elif score >= 3:
        confidence = "mittel"
    else:
        confidence = "niedrig"

    return {"treffer": matches, "score": score, "vertrauen": confidence}


def get_network_type(geo_data: dict) -> str:
    if geo_data.get("hosting"):
        return "Hosting / Rechenzentrum"
    if geo_data.get("proxy"):
        return "Proxy / VPN / Relay moeglich"
    if geo_data.get("mobile"):
        return "Mobiles Netz"
    return "Normales Netz / unbekannt"


def detect_provider(org: str, isp: str, asn: str, reverse_dns: str) -> dict:
    haystack = " ".join([org or "", isp or "", asn or "", reverse_dns or ""]).lower()

    patterns = [
        ("Cloudflare", "CDN / Edge", ["cloudflare"]),
        ("Fastly", "CDN / Edge", ["fastly"]),
        ("Akamai", "CDN / Edge", ["akamai"]),
        ("Amazon Web Services", "Cloud / Hosting", ["amazon", "aws", "amazon web services"]),
        ("Google Cloud / Google", "Cloud / Edge", ["google", "1e100", "googleusercontent"]),
        ("Microsoft Azure", "Cloud / Hosting", ["microsoft", "azure"]),
        ("Hetzner", "Hosting", ["hetzner"]),
        ("OVH", "Hosting", ["ovh"]),
        ("DigitalOcean", "Hosting", ["digitalocean"]),
        ("Linode / Akamai", "Hosting / Cloud", ["linode"]),
        ("GitHub", "Platform / Edge", ["github"]),
        ("Oracle Cloud", "Cloud / Hosting", ["oracle"]),
        ("Mullvad", "VPN / Privacy", ["mullvad"]),
        ("NordVPN", "VPN", ["nordvpn"]),
        ("Surfshark", "VPN", ["surfshark"]),
        ("Proton", "VPN / Privacy", ["proton"]),
    ]

    for name, kind, keys in patterns:
        if any(key in haystack for key in keys):
            return {"provider": name, "typ": kind}

    return {"provider": "-", "typ": "Unbekannt / nicht erkannt"}


def vpn_proxy_assessment(primary: dict, secondary: dict, provider: dict) -> dict:
    score = 0
    reasons = []

    if primary.get("proxy"):
        score += 2
        reasons.append("ip-api meldet Proxy/VPN-Verdacht")
    if primary.get("hosting"):
        score += 1
        reasons.append("IP wirkt wie Hosting/Rechenzentrum")
    if primary.get("mobile"):
        reasons.append("mobiles Netz erkannt")
    if "vpn" in provider.get("typ", "").lower():
        score += 2
        reasons.append(f"Provider-Typ deutet auf {provider.get('typ')}")
    if provider.get("provider", "").lower() in {"mullvad", "nordvpn", "surfshark", "proton"}:
        score += 2
        reasons.append(f"VPN-Anbieter erkannt: {provider.get('provider')}")

    org2 = str(secondary.get("organisation", "")).lower()
    if any(x in org2 for x in ["vpn", "privacy", "proxy"]):
        score += 1
        reasons.append("sekundäre Quelle deutet auf VPN/Proxy")

    if score >= 4:
        level = "hoch"
    elif score >= 2:
        level = "mittel"
    else:
        level = "niedrig"

    return {
        "verdacht": level,
        "gruende": reasons or ["keine starken VPN-/Proxy-Indikatoren erkannt"],
    }


def run_ping(target: str) -> dict:
    ping_path = shutil.which("ping")
    ping6_path = shutil.which("ping6")
    is_v6 = ":" in target

    if is_v6 and ping6_path:
        cmd = [ping6_path, "-c", "3", target]
    elif ping_path:
        cmd = [ping_path, "-c", "3", target]
    else:
        return {"status": "error", "message": "ping ist auf diesem System nicht verfügbar."}

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=15, check=False)
    except subprocess.TimeoutExpired:
        return {"status": "error", "message": "ping Timeout."}
    except Exception as exc:
        return {"status": "error", "message": f"ping Fehler: {exc}"}

    output = ((result.stdout or "") + ("\n" + result.stderr if result.stderr else "")).strip()
    packet_line = ""
    rtt_line = ""

    for line in output.splitlines():
        stripped = line.strip()
        if "packets transmitted" in stripped:
            packet_line = stripped
        if "round-trip min/avg/max" in stripped or "rtt min/avg/max" in stripped:
            rtt_line = stripped

    if result.returncode != 0 and not packet_line:
        return {"status": "error", "message": output or "ping fehlgeschlagen."}

    return {"status": "ok", "packets": packet_line or "-", "rtt": rtt_line or "-"}


def run_traceroute(target: str) -> dict:
    traceroute_path = shutil.which("traceroute")
    if not traceroute_path:
        return {"status": "error", "message": "traceroute ist auf diesem System nicht verfügbar."}

    try:
        result = subprocess.run(
            [traceroute_path, "-m", "12", target],
            capture_output=True,
            text=True,
            timeout=30,
            check=False,
        )
    except subprocess.TimeoutExpired:
        return {"status": "error", "message": "traceroute Timeout."}
    except Exception as exc:
        return {"status": "error", "message": f"traceroute Fehler: {exc}"}

    output = (result.stdout or "").strip()
    if not output:
        return {"status": "error", "message": "Keine traceroute Ausgabe erhalten."}

    return {"status": "ok", "lines": output.splitlines()[:15]}


COMMON_SERVICES = {
    21: "ftp",
    22: "ssh",
    25: "smtp",
    53: "dns",
    80: "http",
    110: "pop3",
    143: "imap",
    443: "https",
    465: "smtps",
    587: "submission",
    993: "imaps",
    995: "pop3s",
    3306: "mysql",
    5432: "postgresql",
    6379: "redis",
    8080: "http-alt",
    8443: "https-alt",
}


def parse_ports(port_text: str | None) -> list[int] | None:
    if not port_text:
        return None

    ports = []
    for item in port_text.split(","):
        item = item.strip()
        if not item:
            continue
        port = int(item)
        if not 1 <= port <= 65535:
            raise ValueError(f"Ungültiger Port: {port}")
        ports.append(port)

    return ports or None


def guess_service(port: int, banner: str) -> str:
    low = banner.lower()

    if "ssh-" in low:
        return "ssh"
    if "smtp" in low:
        return "smtp"
    if "http/" in low or "server:" in low or "html" in low:
        return "http"
    if "redis" in low:
        return "redis"
    if "mysql" in low:
        return "mysql"

    return COMMON_SERVICES.get(port, "-")


def try_banner(ip: str, port: int, timeout: float = 1.5) -> tuple[str, str]:
    try:
        infos = socket.getaddrinfo(ip, port, proto=socket.IPPROTO_TCP)
    except Exception:
        return "-", "-"

    for info in infos:
        af, socktype, proto, _, sockaddr = info
        sock = None
        try:
            sock = socket.socket(af, socktype, proto)
            sock.settimeout(timeout)
            if sock.connect_ex(sockaddr) != 0:
                sock.close()
                continue

            if port in (80, 8080):
                sock.sendall(b"HEAD / HTTP/1.0\r\nHost: localhost\r\n\r\n")
            elif port in (443, 8443):
                return "https", "TLS Dienst erkannt"

            data = sock.recv(256)
            banner = data.decode("utf-8", errors="replace").strip()
            return guess_service(port, banner), banner[:200] if banner else "-"
        except Exception:
            continue
        finally:
            if sock is not None:
                sock.close()

    return COMMON_SERVICES.get(port, "-"), "-"


def check_ports(ip: str, ports: list[int], timeout: float = 1.5) -> list[dict]:
    results = []

    for port in ports:
        status = "closed"
        banner = "-"
        service = "-"
        sock = None

        try:
            infos = socket.getaddrinfo(ip, port, proto=socket.IPPROTO_TCP)
            for info in infos:
                af, socktype, proto, _, sockaddr = info
                sock = socket.socket(af, socktype, proto)
                sock.settimeout(timeout)
                if sock.connect_ex(sockaddr) == 0:
                    status = "open"
                    sock.close()
                    sock = None
                    service, banner = try_banner(ip, port, timeout)
                    break
                sock.close()
                sock = None
        except Exception:
            status = "error"
        finally:
            if sock is not None:
                sock.close()

        results.append({
            "port": port,
            "status": status,
            "service": service,
            "banner": banner,
        })

    return results


def tls_analysis(hostname: str | None, ip: str, port: int = 443, timeout: float = 3.0) -> dict:
    server_name = hostname or ip
    try:
        context = ssl.create_default_context()
        with socket.create_connection((ip, port), timeout=timeout) as sock:
            with context.wrap_socket(sock, server_hostname=server_name) as ssock:
                cert = ssock.getpeercert()
                cipher = ssock.cipher()
                version = ssock.version()

        subject = dict(x[0] for x in cert.get("subject", [])) if cert.get("subject") else {}
        issuer = dict(x[0] for x in cert.get("issuer", [])) if cert.get("issuer") else {}

        sans = []
        for san in cert.get("subjectAltName", []):
            if len(san) == 2 and san[0] == "DNS":
                sans.append(san[1])

        return {
            "status": "ok",
            "tls_version": version or "-",
            "cipher": cipher[0] if cipher else "-",
            "subject_cn": subject.get("commonName", "-"),
            "issuer_cn": issuer.get("commonName", "-"),
            "not_before": cert.get("notBefore", "-"),
            "not_after": cert.get("notAfter", "-"),
            "san_dns": sans[:20],
        }
    except Exception as exc:
        return {
            "status": "error",
            "message": str(exc),
        }


def detect_cdn_from_headers(headers: dict[str, str]) -> dict:
    joined = " ".join(f"{k}:{v}" for k, v in headers.items()).lower()

    patterns = [
        ("Cloudflare", ["cloudflare", "cf-ray", "cf-cache-status", "__cf_bm"]),
        ("Fastly", ["fastly", "x-served-by", "x-cache", "fastly-debug"]),
        ("Akamai", ["akamai", "akamai-grn"]),
        ("CloudFront", ["cloudfront", "x-amz-cf-id", "x-amz-cf-pop"]),
        ("GitHub Pages / GitHub", ["github", "x-github-request-id"]),
        ("Vercel", ["vercel", "x-vercel-id"]),
        ("Netlify", ["netlify"]),
    ]

    for name, keys in patterns:
        if any(key in joined for key in keys):
            return {"erkannt": True, "name": name}

    return {"erkannt": False, "name": "-"}


def analyze_http(target: str, hostname: str | None) -> dict:
    host = hostname or target
    schemes = ["https", "http"]
    last_error = "-"

    for scheme in schemes:
        url = f"{scheme}://{host}"
        req = urllib.request.Request(
            url,
            headers={
                "User-Agent": f"woist/{APP_VERSION}",
                "Accept": "*/*",
            },
            method="GET",
        )

        try:
            with urllib.request.urlopen(req, timeout=8) as response:
                headers = {k.lower(): v for k, v in response.headers.items()}
                status = getattr(response, "status", getattr(response, "code", "-"))
                final_url = response.geturl()

                security_headers = {
                    "strict-transport-security": headers.get("strict-transport-security", "-"),
                    "content-security-policy": headers.get("content-security-policy", "-"),
                    "x-frame-options": headers.get("x-frame-options", "-"),
                    "x-content-type-options": headers.get("x-content-type-options", "-"),
                    "referrer-policy": headers.get("referrer-policy", "-"),
                    "permissions-policy": headers.get("permissions-policy", "-"),
                }

                present = sum(1 for value in security_headers.values() if value != "-")
                if present >= 5:
                    score = "hoch"
                elif present >= 3:
                    score = "mittel"
                else:
                    score = "niedrig"

                cdn = detect_cdn_from_headers(headers)

                return {
                    "status": "ok",
                    "scheme": scheme,
                    "url": final_url,
                    "http_status": status,
                    "server": headers.get("server", "-"),
                    "x_powered_by": headers.get("x-powered-by", "-"),
                    "via": headers.get("via", "-"),
                    "security_headers": security_headers,
                    "security_score": score,
                    "cdn": cdn,
                }
        except urllib.error.HTTPError as exc:
            headers = {k.lower(): v for k, v in exc.headers.items()} if exc.headers else {}
            security_headers = {
                "strict-transport-security": headers.get("strict-transport-security", "-"),
                "content-security-policy": headers.get("content-security-policy", "-"),
                "x-frame-options": headers.get("x-frame-options", "-"),
                "x-content-type-options": headers.get("x-content-type-options", "-"),
                "referrer-policy": headers.get("referrer-policy", "-"),
                "permissions-policy": headers.get("permissions-policy", "-"),
            }
            cdn = detect_cdn_from_headers(headers)

            return {
                "status": "ok",
                "scheme": scheme,
                "url": url,
                "http_status": exc.code,
                "server": headers.get("server", "-"),
                "x_powered_by": headers.get("x-powered-by", "-"),
                "via": headers.get("via", "-"),
                "security_headers": security_headers,
                "security_score": "niedrig",
                "cdn": cdn,
            }
        except Exception as exc:
            last_error = str(exc)

    return {
        "status": "error",
        "message": last_error,
    }


def export_results(path: str, results: list[dict]) -> None:
    target = Path(path)
    suffix = target.suffix.lower()

    if suffix == ".json":
        target.write_text(
            json.dumps(results if len(results) > 1 else results[0], ensure_ascii=False, indent=2),
            encoding="utf-8",
        )
        return

    if suffix == ".csv":
        rows = []
        for result in results:
            dns = result["dns"]
            geo = result["geoip"]["primaer"]
            asn = result["asn"]
            http_data = result.get("http")
            rows.append({
                "eingabe": result["eingabe"],
                "typ": result["typ"],
                "bevorzugte_ip": dns["bevorzugte_ip"],
                "reverse_dns": dns["reverse_dns_lokal"],
                "land": geo.get("land", "-"),
                "region": geo.get("region", "-"),
                "stadt": geo.get("stadt", "-"),
                "isp": geo.get("isp", "-"),
                "organisation": geo.get("organisation", "-"),
                "as": geo.get("as", "-"),
                "provider": geo.get("provider_erkannt", "-"),
                "vpn_verdacht": geo.get("vpn_proxy_verdacht", {}).get("verdacht", "-"),
                "cidr": asn.get("cidr", "-"),
                "rir": asn.get("rir", "-"),
                "owner": asn.get("owner", "-"),
                "http_status": http_data.get("http_status", "-") if http_data else "-",
                "server": http_data.get("server", "-") if http_data else "-",
                "cdn": http_data.get("cdn", {}).get("name", "-") if http_data else "-",
                "security_score": http_data.get("security_score", "-") if http_data else "-",
            })

        with target.open("w", newline="", encoding="utf-8") as f:
            writer = csv.DictWriter(f, fieldnames=list(rows[0].keys()) if rows else ["eingabe"])
            writer.writeheader()
            for row in rows:
                writer.writerow(row)
        return

    if suffix == ".md":
        lines = ["# woist Report", ""]
        for result in results:
            dns = result["dns"]
            geo = result["geoip"]["primaer"]
            asn = result["asn"]
            http_data = result.get("http")
            lines.append(f"## {result['eingabe']}")
            lines.append("")
            lines.append(f"- Typ: {result['typ']}")
            lines.append(f"- Bevorzugte IP: {dns['bevorzugte_ip']}")
            lines.append(f"- Reverse DNS: {dns['reverse_dns_lokal']}")
            lines.append(f"- Land: {geo.get('land', '-')}")
            lines.append(f"- Region: {geo.get('region', '-')}")
            lines.append(f"- Stadt: {geo.get('stadt', '-')}")
            lines.append(f"- ISP: {geo.get('isp', '-')}")
            lines.append(f"- Organisation: {geo.get('organisation', '-')}")
            lines.append(f"- AS: {geo.get('as', '-')}")
            lines.append(f"- Provider: {geo.get('provider_erkannt', '-')}")
            lines.append(f"- VPN/Proxy-Verdacht: {geo.get('vpn_proxy_verdacht', {}).get('verdacht', '-')}")
            lines.append(f"- CIDR: {asn.get('cidr', '-')}")
            lines.append(f"- RIR: {asn.get('rir', '-')}")
            lines.append(f"- Owner: {asn.get('owner', '-')}")
            if http_data:
                lines.append(f"- HTTP Status: {http_data.get('http_status', '-')}")
                lines.append(f"- Server: {http_data.get('server', '-')}")
                lines.append(f"- CDN: {http_data.get('cdn', {}).get('name', '-')}")
                lines.append(f"- Security Score: {http_data.get('security_score', '-')}")
            lines.append("")
        target.write_text("\n".join(lines), encoding="utf-8")
        return

    raise ValueError("Nicht unterstütztes Exportformat. Nutze .json, .csv oder .md")


def build_asn_block(primary: dict, secondary: dict, whois_info: dict) -> dict:
    raw_as = str(primary.get("as", "-"))
    as_number = "-"
    as_name = "-"

    if raw_as.startswith("AS"):
        parts = raw_as.split(" ", 1)
        as_number = parts[0]
        as_name = parts[1] if len(parts) > 1 else "-"

    cidr = whois_info.get("cidr", "-")
    if cidr == "-" and isinstance(secondary.get("network"), dict):
        cidr = secondary["network"].get("cidr", "-")

    return {
        "as_raw": raw_as,
        "as_number": as_number,
        "as_name": as_name,
        "cidr": cidr,
        "route": whois_info.get("route", "-"),
        "inetnum": whois_info.get("inetnum", "-"),
        "inet6num": whois_info.get("inet6num", "-"),
        "netname": whois_info.get("netname", "-"),
        "owner": whois_info.get("owner", "-"),
        "org": whois_info.get("org", "-"),
        "country": whois_info.get("country", "-"),
        "origin": whois_info.get("origin", "-"),
        "rir": whois_info.get("rir", "-"),
    }


def build_result(
    dns_result: dict,
    geo_primary: dict,
    geo_secondary: dict,
    whois_text: str | None,
    ping_data: dict | None,
    trace_data: dict | None,
    port_data: list[dict] | None,
    tls_data: dict | None,
    http_data: dict | None,
    cache_hit: bool,
) -> dict:
    geo_compare = compare_geo_sources(geo_primary, geo_secondary)
    provider = detect_provider(
        geo_primary.get("organisation", "-"),
        geo_primary.get("isp", "-"),
        geo_primary.get("as", "-"),
        dns_result.get("reverse_dns", "-"),
    )
    vpn_assessment = vpn_proxy_assessment(geo_primary, geo_secondary, provider)

    geo_primary["netztyp"] = get_network_type(geo_primary)
    geo_primary["provider_erkannt"] = provider["provider"]
    geo_primary["provider_typ"] = provider["typ"]
    geo_primary["vpn_proxy_verdacht"] = vpn_assessment

    whois_info = extract_whois_network_info(whois_text or "")
    asn_block = build_asn_block(geo_primary, geo_secondary, whois_info)

    return {
        "eingabe": dns_result["eingabe"],
        "typ": dns_result["typ"],
        "hostname": dns_result["hostname"],
        "cache_hit": cache_hit,
        "dns": {
            "cname": dns_result["cname"],
            "a": dns_result["a"],
            "aaaa": dns_result["aaaa"],
            "mx": dns_result["mx"],
            "ns": dns_result["ns"],
            "txt": dns_result["txt"],
            "ttl": dns_result["ttl"],
            "bevorzugte_ip": dns_result["bevorzugte_ip"],
            "reverse_dns_lokal": dns_result["reverse_dns"],
        },
        "geoip": {
            "hinweis": "GeoIP ist nur eine Schätzung und nicht der exakte physische Serverstandort.",
            "primaer": geo_primary,
            "sekundaer": geo_secondary,
            "vergleich": geo_compare,
        },
        "asn": asn_block,
        "whois": whois_text,
        "ping": ping_data,
        "trace": trace_data,
        "ports": port_data,
        "tls": tls_data,
        "http": http_data,
    }


def analyze_target(
    target: str,
    nameserver: str | None,
    with_whois: bool,
    with_ping: bool,
    with_trace: bool,
    with_tls: bool,
    with_http: bool,
    ports: list[int] | None,
) -> dict:
    dns_result = resolve_target(target, nameserver)
    geo_primary, geo_secondary, cache_hit = lookup_geo_with_cache(dns_result["bevorzugte_ip"])
    whois_text = run_whois(dns_result["bevorzugte_ip"])
    ping_data = run_ping(dns_result["bevorzugte_ip"]) if with_ping else None
    trace_data = run_traceroute(dns_result["bevorzugte_ip"]) if with_trace else None
    port_data = check_ports(dns_result["bevorzugte_ip"], ports) if ports else None
    tls_data = tls_analysis(dns_result["hostname"], dns_result["bevorzugte_ip"]) if with_tls else None
    http_data = analyze_http(dns_result["eingabe"], dns_result["hostname"]) if with_http else None

    return build_result(
        dns_result=dns_result,
        geo_primary=geo_primary,
        geo_secondary=geo_secondary,
        whois_text=whois_text,
        ping_data=ping_data,
        trace_data=trace_data,
        port_data=port_data,
        tls_data=tls_data,
        http_data=http_data,
        cache_hit=cache_hit,
    )


